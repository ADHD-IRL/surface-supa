{
  "name": "Agent",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Agent display name"
    },
    "discipline": {
      "type": "string",
      "description": "Agent discipline or specialty (e.g. SCRM / Hardware Security)"
    },
    "team": {
      "type": "string",
      "enum": [
        "red",
        "blue"
      ],
      "description": "Red team (attacker) or Blue team (defender)"
    },
    "domain_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Domain expertise tags: cyber, geopolitical, financial, operational, strategic"
    },
    "expertise_level": {
      "type": "string",
      "enum": [
        "Junior",
        "Mid-Level",
        "Senior",
        "Principal",
        "World-Class"
      ],
      "default": "Senior",
      "description": "Agent expertise level"
    },
    "reasoning_style": {
      "type": "string",
      "enum": [
        "Analytical",
        "Intuitive",
        "Contrarian",
        "Systematic",
        "Probabilistic"
      ],
      "default": "Analytical",
      "description": "Agent reasoning style"
    },
    "severity_default": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ],
      "default": "HIGH",
      "description": "Default severity lens for this agent"
    },
    "persona_description": {
      "type": "string",
      "description": "3-4 sentence career history and worldview"
    },
    "cognitive_bias": {
      "type": "string",
      "description": "What this agent systematically underweights"
    },
    "red_team_focus": {
      "type": "string",
      "description": "Primary focus: threats the agent hunts (red) or defenses championed (blue)"
    },
    "vector_human": {
      "type": "number",
      "description": "Human threat vector weight 0-100",
      "default": 50
    },
    "vector_technical": {
      "type": "number",
      "description": "Technical threat vector weight 0-100",
      "default": 50
    },
    "vector_physical": {
      "type": "number",
      "description": "Physical threat vector weight 0-100",
      "default": 30
    },
    "vector_futures": {
      "type": "number",
      "description": "Futures/emerging threat vector weight 0-100",
      "default": 40
    },
    "tone": {
      "type": "string",
      "enum": [
        "aggressive",
        "analytical",
        "cautious",
        "provocative",
        "measured"
      ],
      "default": "analytical",
      "description": "Communication tone of the agent"
    },
    "system_prompt": {
      "type": "string",
      "description": "Legacy system prompt (used if persona_description is not set)"
    },
    "is_default": {
      "type": "boolean",
      "default": false,
      "description": "Whether this is a built-in default agent"
    },
    "avatar_color": {
      "type": "string",
      "description": "Hex color for avatar"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    }
  },
  "required": [
    "name",
    "team"
  ]
}
